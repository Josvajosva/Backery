<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_create_purchase_orders" model="ir.cron">
            <field name="name">Create Purchase Orders from Orderpoints</field>
            <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
            <field name="state">code</field>
            <field name="code">model.create_purchase_orders_from_orderpoints()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="DateTime.now().replace(hour=11, minute=0, second=0)"/>
        </record>

        <record id="ir_cron_update_purchase_orders" model="ir.cron">
            <field name="name">Update Purchase Orders</field>
            <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
            <field name="state">code</field>
            <field name="code">model.update_purchase_orders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="DateTime.now().replace(hour=11, minute=30, second=0)"/>
        </record>
    </data>
</odoo>