<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_po_scheduler_config_list" model="ir.ui.view">
        <field name="name">po.scheduler.config.list</field>
        <field name="model">po.scheduler.config</field>
        <field name="arch" type="xml">
            <list string="PO Scheduler Configurations" create="0" delete="1">
                <field name="name"/>
                <field name="execution" string="Execution"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_po_scheduler_config_form" model="ir.ui.view">
        <field name="name">po.scheduler.config.form</field>
        <field name="model">po.scheduler.config</field>
        <field name="arch" type="xml">
            <form string="PO Scheduler Configuration" create="0" delete="0">
                <header>
                    <button name="create_po_order" string="Create PO Order" type="object" class="oe_highlight" invisible="type == 'update'" />
                    <button name="update_po_order" string="Update PO Order" type="object" class="oe_highlight" invisible="type == 'create'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="type" invisible="1"/>
                            <field name="name" placeholder="Configuration Name"/>
                            <field name="cron_id" readonly="1"/>
                            <field
                                    name="execution"
                                    string="Execution Date"
                                    required="1"
                                   help="Set the date and time for the next execution. The cron will run daily at this time."
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_po_scheduler_config" model="ir.actions.act_window">
        <field name="name">PO Scheduler Configuration</field>
        <field name="res_model">po.scheduler.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new PO Scheduler Configuration
            </p>
            <p>
                Configure the automatic purchase order creation from orderpoints.
                Set the execution time, interval, and manage the cron job.
            </p>
        </field>
    </record>

    <menuitem id="menu_po_scheduler_config"
              name="PO Scheduler Configuration"
              parent="stock.menu_stock_config_settings"
              action="action_po_scheduler_config"
              sequence="100"/>
</odoo>
