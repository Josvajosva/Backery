<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_grn_validation" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.grn.validation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="inside">
                <group string="GRN Configuration">
                    <field name="validate_grn_from_invoice"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>