<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_cash_report_wizard_form" model="ir.ui.view">
        <field name="name">sale.cash.report.wizard.form</field>
        <field name="model">sale.cash.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Sale Report Wizard">
                <group>
                    <group>
                        <field name="from_date"/>
                        <field name="company_id" invisible="1"/>
                        <field name="xls_file" readonly="1"/>
                    </group>
                    <group>
                        <!-- <field name="to_date"/> -->
                        <field name="company_ids" widget="many2many_tags"/>
                        <field name="xls_filename" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="actions_fixed_reports" type="object" string="Generate Report" class="btn-primary"/>
                    <!-- <button name="generate_report" type="object" string="Generate Report" class="btn-primary"/> -->
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="action_sale_cash_report_wizard" model="ir.actions.act_window">
        <field name="name">Sale Cash Report</field>
        <field name="res_model">sale.cash.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sale_cash_report" name="Sales Cash Report" parent="sale.menu_sale_report"
    action="action_sale_cash_report_wizard" sequence="150"/>

</odoo>
