<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_inherited11" model="ir.ui.view">
        <field name="name">account.payment.inherited11</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_bank_id']" position="after">
                <field name="settlement" invisible="payment_type != 'inbound'" readonly="state == 'paid'"/>
            </xpath>
        </field>
    </record>
</odoo>