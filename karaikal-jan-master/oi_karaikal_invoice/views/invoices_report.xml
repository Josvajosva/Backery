								<t t-set="l10n_in_einvoice_json" t-value="doc._get_l10n_in_edi_response_json()"/>
								 <t t-if="l10n_in_einvoice_json">
							<b><span style="padding-left:8px;">IRN No:</span></b>
							<span t-esc="l10n_in_einvoice_json['Irn']"/>
						</t><br/>
							  </td>
							</tr>
					 
							  <td width="20%!important" style="border:hidden;;padding:10px;padding-left:10px; ">
								<t t-set="l10n_in_einvoice_json" t-value="doc._get_l10n_in_edi_response_json()"/>
								  <div t-if="l10n_in_einvoice_json">
							  			<img t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' %('QR', l10n_in_einvoice_json['SignedQRCode'], 300, 300)" style="max-height: 122px"/>
								  </div>
							  </td>
							  
							  <td width="33%!important" style="border:hidden;; vertical-align: top;padding-left:10px;">
								
	
