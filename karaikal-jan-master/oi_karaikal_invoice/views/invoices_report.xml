                        </td>
                        <td width="5%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px">
                            <span/>
                            <t t-esc="line.product_uom_id.name"/>
                        </td>
                        <td width="10%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px">
                            <span/>
                            <t t-esc="line.price_subtotal" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/>
                        </td>
                    </tr>
                    
                    
                    
                    
                    <tr width="100%" style="border:1px solid black">
                        
