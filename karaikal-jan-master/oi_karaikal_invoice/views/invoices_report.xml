                        <table width="100%" style="border:1px solid black;padding:3px">
                            <tr>
                                <td rowspan="3" width="50%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <!--<span>Customer Name &amp; Address:</span>-->
                                    <!--<br/>-->
                                   <b> <span style="font-size:17px" t-field="doc.company_id.name"/></b>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.company_id.street"/>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.company_id.street2"/>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.company_id.city"/>
                                    <br/>
                                    <span>GSTIN/UIN :</span><span style="font-size:15px;padding-left:5px" t-field="doc.company_id.vat"/><br/>
                                   <span>State Name : </span> <span style="font-size:15px;padding-left:5px" t-field="doc.company_id.state_id.name"/> <span t-if="doc.company_id.state_id.name">,</span> <span t-field="doc.company_id.state_id.code"/><br/>
                                    <span>E-Mail :</span><span style="font-size:15px ;padding-left:5px" t-field="doc.company_id.email"/>
        
                                </td>
                                <td width="25%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span style="text-align:left">Invoice No.</span> <span style="padding-left:15px">e-Way Bill No.</span><br/>
                                   <b><span style="text-align:left" t-field="doc.name"/></b> 
                                </td>
                                <td width="25%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span>Dated</span><br/>
                                    <b><span t-field="doc.invoice_date"/></b>
                                </td>
                            </tr>
                            <tr>
                                <td width="25%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span>Delivery Note</span>
