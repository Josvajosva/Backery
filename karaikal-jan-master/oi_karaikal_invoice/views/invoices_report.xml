<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="invoice_print_out_header_template">
            <div t-attf-class="header" t-att-style="report_header_style"/>
            <div t-attf-class="article o_report_layout_standard "
                t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id"
                t-att-data-oe-lang="o and o.env.context.get('lang')">
                <t t-out="0"/>
            </div>
            <div t-attf-class="footer o_standard_footer"/>
        </template>

        <template id="invoice_print_out_body_template">
            <t t-call="oi_karaikal_invoice.invoice_print_out_header_template">
                <t t-foreach="docs" t-as="doc"/>
                        <div class="page" style="position: relative;">
                                <!-- Intercompany QR Code: encodes PO_id|Invoice_id -->
                                <t t-if="doc.is_intercompany_so_invoice">
                                    <t t-set="so_ids" t-value="doc._get_intercompany_po_ids()"/>
                                    <t t-set="qr_value" t-value="'%s|%s' % (so_ids, doc.id)"/>
                                    <div style="text-align: right; position: absolute; top: -50px; right: 0px;">
                                        <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=120&amp;height=120' % qr_value"
                                             alt="QR"
                                             style="width: 70px; height: 70px; display: block;"/>
                                    </div>
                                </t>

                                <h4 class="text-center">
                                    <strong>
                                        Tax Invoice
                                    </strong>
                                </h4>


                                <!--<div style="display: flex; justify-content: space-between; align-items: flex-start;">-->
                                    <!-- Left section with IRN, Ack No, and Ack Date -->
                                <!--    <div>-->
                                <!--        <span>IRN:</span> -->
                                        <!--<span t-esc="doc.irn" />-->
                                <!--        <br/>-->
                                <!--        <span>Ack No:</span>-->
                                        <!--<span t-esc="doc.ack_no" />-->
                                <!--        <br/>-->
                                <!--        <span>Ack Date:</span>-->
                                        <!--<span t-esc="doc.ack_date" />-->
                                <!--    </div>-->
                                    <!-- Right section with QR Code -->
