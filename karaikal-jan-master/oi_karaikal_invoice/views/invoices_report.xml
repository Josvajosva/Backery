                            <th width="10%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px">Amount</th>
                        </b>
                    </tr>
                    <t t-set="i" t-value="1"/>
                    <tr width="100%" t-foreach="doc.invoice_line_ids" t-as="line" style="border:1px solid black;padding:3px">
                        <td width="5%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px">
                            <span t-esc="i"/>
                            <t t-set="i" t-value="i+1"/>
                        </td>
                        <td width="45%" style="text-align:left;border:1px solid black;font-size:15px;padding:3px">
                            <span t-esc="line.name"/>
                        </td>
                        <td width="9%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px">
                            <span t-field="line.l10n_in_hsn_code"/>
                        </td>
                        <td width="10%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px">
                            <span/>
                            <span t-field="line.quantity"/>
                        </td>
                        <td width="12%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px">
                            <t t-if="line.price_subtotal">
                                <span t-esc="line.price_subtotal / line.quantity" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/>
                            </t>
                            <t t-else="">
                                <span>0.0</span>
                            </t>
                        </td>
                        <!-- <td width="12%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px">
                            <span/>
                            <span t-field="line.price_subtotal"/>
