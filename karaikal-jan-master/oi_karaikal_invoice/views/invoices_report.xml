                                </td>
                                <td width="25%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span>Mode/Terms of Payment</span>
                                    <b><span t-field="doc.invoice_payment_term_id"/></b>
                                </td>
                            </tr>
                            <tr>
                                <td width="25%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span>Reference No. &amp; Date.</span>
                                </td>
                                <td width="25%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span>Other References</span>
                                
                                </td>
                            </tr>
                            <tr>
                                <td width="50%" style="border:1px solid black;font-size:15px;padding:3px">
                                    <span>
                                            Buyer (Bill to)
                                        </span>
                                    <br/>
                                     <b> <span style="font-size:17px" t-field="doc.partner_shipping_id.name"/></b>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.partner_shipping_id.street"/>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.partner_shipping_id.street2"/>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.partner_shipping_id.city"/>
