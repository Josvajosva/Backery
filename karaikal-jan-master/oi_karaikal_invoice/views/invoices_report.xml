                                <t t-set="total_exclu" t-value="sum(line.price_subtotal for line in doc.invoice_line_ids)"/>
                            <t t-esc="total_exclu" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/>
                        </td>
                        
                        
                    </tr>
                </table>
                    
