<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="e_way_bill_out_header_template">
            <div t-attf-class="header" t-att-style="report_header_style"/>
            <div t-attf-class="article o_report_layout_standard "
                t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id"
                t-att-data-oe-lang="o and o.env.context.get('lang')">
                <t t-out="0"/>
            </div>
            <div t-attf-class="footer o_standard_footer"/>
        </template>

        <template id="e_way_bill_out_body_template">
            <t t-call="oi_karaikal_invoice.e_way_bill_out_header_template">
                <t t-foreach="docs" t-as="doc"/>
               <div class="page">
                    <h5 class="text-center">
                                    <strong>
                                       e-Way Bill
                                    </strong><br/>
                                    <t t-set="l10n_in_ewaybill_json" t-value="doc._get_l10n_in_edi_ewaybill_response_json()"/>
                            <img t-if="'EwbNo' in l10n_in_ewaybill_json and 'EwbDt' in l10n_in_ewaybill_json"
                                 t-att-src="'/report/barcode/QR/' +  str(l10n_in_ewaybill_json['EwbNo']) + '/' + str(doc.company_id.vat) + '/' + str(l10n_in_ewaybill_json['EwbDt'])"
                                 style="width: 6.25rem; height: 6.25rem;text-align:center;" alt="Barcode"/>
                    </h5>
                    <table width="100%" style="border:1px solid black;padding:3px">
                        <tr>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px">
                                <b>1. e-Way Bill Details</b></td>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%"/>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%"/>
                            
                        </tr>
                        <tr>
                            <t t-set="l10n_in_ewaybill_json" t-value="doc._get_l10n_in_edi_ewaybill_response_json()"/>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"><strong>e-Way Bill No : </strong><p t-if="'EwbNo' in l10n_in_ewaybill_json" class="m-0" t-esc="l10n_in_ewaybill_json['EwbNo']"/>
                             
                                </td>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Mode:</strong>  <br/><span style="font-size:17px" t-field="doc.l10n_in_mode"/>
                            </td>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px">
                                 <t t-set="l10n_in_ewaybill_json" t-value="doc._get_l10n_in_edi_ewaybill_response_json()"/>
                                <p t-if="'EwbDt' in l10n_in_ewaybill_json">
                                    <strong>Generated Date: <br/></strong><t t-esc="l10n_in_ewaybill_json['EwbDt']"/>
                                </p>
                            
                            </td>
                           
                        </tr>
                        <tr>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Generated By :</strong><br/><span style="font-size:17px" t-field="doc.partner_id.vat"/><br/><span style="font-size:17px" t-field="doc.partner_id.name"/>
                            </td>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Approx Distance :</strong><br/><span style="font-size:17px" t-field="doc.l10n_in_distance"/>
                            </td>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Valid Upto :</strong><br/>
                             <p t-if="'ewayBillNo' in l10n_in_ewaybill_json" class="m-0" t-esc="l10n_in_ewaybill_json['ewayBillNo']"/>
                                <t t-if="'EwbValidTill' in l10n_in_ewaybill_json" class="m-0" t-esc="l10n_in_ewaybill_json['EwbValidTill']"/>
                                <t t-if="'validUpto' in l10n_in_ewaybill_json" class="m-0" t-esc="l10n_in_ewaybill_json['validUpto']"/></td>
                            
                        </tr>
                         <tr>
                            <td style="border-top:hidden;border-left:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Supply Type :</strong><br/><span style="font-size:17px" t-field="doc.l10n_in_type_id"/>
                            
                            </td>
                            <td style="border-top:hidden;border-left:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Transaction Type:</strong><br/><span style="font-size:17px" t-field="doc.l10n_in_vehicle_type"/>
                            </td>
                            <td style="border-top:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px"/>
                        </tr>
                    </table>
                    
                    <table width="100%" style="border:1px solid black;padding:3px">
                        
                        <tr>
                            <td style="border:hidden;padding:3px;width:50%;font-size:17px"><b>2. Address Details</b></td>
                            <td style="border:hidden;padding:3px;width:50%;font-size:17px"/>
                        </tr>
                        <tr>
                            <td style="border:hidden;padding:3px;width:50%;font-size:17px">
                                <span><b>From</b></span>
                            </td>
                            <td style="border:hidden;padding:3px;width:50%;font-size:17px">
                                <span><b>To</b></span>
                            </td>
                            
                            
                        </tr>
                         <tr>
                            <td style="border-top:hidden;border-left:hidden;padding:3px;width:33.33%;font-size:17px">
                                <span t-esc="doc.company_id.name"/><br/>
                                <span style="font-size:15px" t-field="doc.company_id.street"/>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.company_id.street2"/>
                                    <br/>
                                    <span style="font-size:15px" t-field="doc.company_id.city"/><br/>
                                    <span style="font-size:15px" t-field="doc.company_id.state_id.name"/> <span style="font-size:15px" t-field="doc.company_id.zip"/><br/>
                                    
                                    <span style="font-size:15px" t-field="doc.company_id.country_id.name"/><br/>
                               <span>GSTIN : </span><Span t-esc="doc.company_id.vat"/><span/>
                            </td>
                            <td style="border-top:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px">
                                <span t-esc="doc.partner_shipping_id.name"/><br/>
                                <span style="font-size:15px" t-field="doc.company_id.city"/><br/>
                                    <span style="font-size:15px" t-field="doc.company_id.state_id.name"/> <span style="font-size:15px" t-field="doc.company_id.zip"/><br/>
                                    
                                    <span style="font-size:15px" t-field="doc.company_id.country_id.name"/><br/>
                                <span>GSTIN : </span><Span t-esc="doc.partner_id.vat"/>

                            </td>
                        </tr>
                    </table>
                    
                    <table width="100%" style="border:1px solid black;padding:3px">
                        
                        <tr>
                            <td style="border:hidden;padding:3px;width:50%;font-size:17px"><b>3. Goods Details</b></td>
                            <td style="border:hidden;padding:3px;width:50%;font-size:17px"/>
                        </tr>
                        
                    </table>
                    
                    <table style="border: 1px solid black;width:100%;padding:3px">
                    <tr width="100%" style="border:1px solid black">
                        <b>
                            <!--<th width="5%" style="text-align:center;border:1px solid black;border-right:hidden;border-left:hidden;font-size:15px;padding:3px">Sl.No</th>-->
                            <th width="10%" style="text-align:center;border:1px solid black;border-right:hidden;border-left:hidden;font-size:15px;padding:3px"><b>HSN Code</b></th>
                            <th width="45%" style="text-align:center;border:1px solid black;border-right:hidden;font-size:15px;padding:3px"><b>Product Name &amp; Desc</b></th>
                            <th width="10%" style="text-align:center;border:1px solid black;border-right:hidden;font-size:15px;padding:3px"><b>Quantity</b></th>
                            <th width="15%" style="text-align:right;border:1px solid black;border-right:hidden;font-size:15px;padding:3px"><b>Taxable Amt</b></th>
                            <th width="20%" style="text-align:right;border:1px solid black;border-right:hidden;font-size:15px;padding:3px"><b>Tax Rate</b></th>
                        </b>
                    </tr>
                    <t t-set="i" t-value="1"/>
                    <tr width="100%" t-foreach="doc.invoice_line_ids" t-as="line" style="border:1px solid black;padding:3px">
                        <!--<td width="5%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px;border-right:hidden;border-left:hidden">-->
                        <!--    <span t-esc="i"/>-->
                        <!--    <t t-set="i" t-value="i+1"/>-->
                        <!--</td>-->
                        <td width="10%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px;border-right:hidden;border-left:hidden">
                            <span t-field="line.l10n_in_hsn_code"/>
                        </td>
                        <td width="45%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px;border-right:hidden">
                            <span t-esc="line.name"/>
                        </td>
                        <td width="10%" style="text-align:center;border:1px solid black;font-size:15px;padding:3px;border-right:hidden">
                            <span/>
                            <span t-field="line.quantity"/>
                        </td>
                        
                        <td width="15%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px;border-right:hidden">
                            <span/>
                            <t t-esc="line.price_subtotal" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/>
                        </td>
                        <td width="20%" style="text-align:right;border:1px solid black;font-size:15px;padding:3px;border-right:hidden">
                        
                            <span t-field="line.tax_ids.name"/>
                        </td>
                        
                    </tr>
                    
                </table>
                
                <br/>
                <br/>
                <br/>
                        <table class="o_total_table table" style="border-right:hidden;border-left:hidden">
                            <t t-call="sale.document_tax_totals">
                                <t t-set="tax_totals" t-value="doc.tax_totals"/>
                                <t t-set="currency" t-value="doc.currency_id"/>
                            </t>
                        </table>
                        
                        <table width="100%" style="border:1px solid black;padding:3px">
                        <tr>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;border-top:hidden;padding:3px;width:33.33%;font-size:17px"><b>4. Transportation Details</b></td>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;border-top:hidden;padding:3px;width:33.33%"/>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"/>
                            
                            
                        </tr>
                        <tr>
                            
                        
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px">
                                <t t-if="doc.l10n_in_mode == '0'">
                                    <strong>Transporter ID:</strong><br/>
                                    <t t-esc="doc.partner_id.vat"/>
                                </t>
                                <t t-if="doc.l10n_in_mode == '1'">
                                    <strong>Transporter ID:</strong><br/>
                                    <t t-esc="doc.company_id.vat"/>
                                </t>
                            </td>
                       
                                            
                                            <!--<td style="border:hidden;padding:3px;width:33.33%;font-size:17px">Transporter ID:<br/><t t-if="doc.l10n_in_mode == '0'" t-esc="doc.partner_id.vat"/>-->
                            
       
                            
                            <!--</td>-->
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"/>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px;"><strong>Doc No:</strong><br/><span style="font-size:17px" t-field="doc.name"/>
                            </td>
                        </tr>
                        
                         <tr>
                            <td style="border-top:hidden;border-left:hidden;padding:3px;width:33.33%;font-size:17px">
                             <t t-if="doc.l10n_in_mode == '0'">
                                   <strong>Name:</strong><br/>
                                    <t t-esc="doc.l10n_in_transporter_id.name"/>
                                </t>
                                <t t-if="doc.l10n_in_mode == '1'">
                                    <strong>Name:</strong><br/>
                                    <t t-esc="doc.company_id.name"/>
                                </t>
                            </td>
                            <td style="border-top:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px"/>
                            <td style="border-top:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Date:</strong><br/><span style="font-size:17px" t-field="doc.invoice_date"/>
                            </td>
                        </tr>
                    </table>
                    
                     <table width="100%" style="border:1px solid black;padding:3px">
                        <tr>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;border-top:hidden;padding:3px;width:33.33%;font-size:17px"><b>5. Vehicle Details</b></td>
                            <td style="border-bottom:hidden;border-left:hidden;border-right:hidden;border-top:hidden;padding:3px;width:33.33%"/>
                            <td style="border:hidden;padding:3px;width:33.33%;font-size:17px"/>
                            
                            
                        </tr>
                        
                        
                         <tr>
                            <td style="border-top:hidden;border-left:hidden;padding:3px;width:33.33%;font-size:17px"><strong>Vehicle No. :</strong><br/><span style="font-size:17px" t-field="doc.l10n_in_vehicle_no"/>
                            </td>
                            <td style="border-top:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px"/>
                            <td style="border-top:hidden;border-left:hidden;border-right:hidden;padding:3px;width:33.33%;font-size:17px">
                             <t t-set="l10n_in_ewaybill_json" t-value="doc._get_l10n_in_edi_ewaybill_response_json()"/>
                                <p t-if="'EwbDt' in l10n_in_ewaybill_json">
                                    <strong>Date: <br/></strong><t t-esc="l10n_in_ewaybill_json['EwbDt']"/>
                                </p>
                            
                            
                            </td>
                        </tr>
                    </table>
                    
            </div>
            </t>
        </template>

        <template id="e_way_bill_action_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="oi_karaikal_invoice.e_way_bill_out_body_template"/>
                </t>
            </t>
        </template>
    </data>
</odoo>
