<odoo>
    <template id="report_product_label_qrcode_inherit" inherit_id="product.report_simple_label_dymo">
        <xpath expr="//div[contains(@class, 'o_label_full')]" position="replace">
            <!-- Compact label layout with NO borders -->
            <div style="width:100%; height:48mm; white-space:nowrap; overflow:hidden;                         font-family:Arial, sans-serif; border:hidden !important; box-shadow:none;">
                <div style="display:inline-block; vertical-align:middle; width:50%;                             white-space:normal; line-height:1.1; margin-right:0;                             border:hidden !important; padding-left:10px;border:hidden">

                    <!--<t t-set="production" t-value="env['mrp.production'].search([('product_id', '=', product.id), ('use_by_date', '!=', False)], limit=1, order='use_by_date desc')"/>-->
                    <t t-set="production"
                       t-value="env['mrp.production'].search([('product_id', '=', product.id), ('date_finished', '!=', False)], limit=1, order='date_finished desc')"/>
                    <div style="font-weight:bold; font-size:9.5px;border:hidden">
                        <span t-field="product.name"/>
                    </div>

                    <div style="font-size:7px;border:hidden">
                        <b>MFG Date:</b>
                        <t t-if="production and production.date_finished">
                            <b>
                                <span t-esc="production.date_finished.strftime('%d/%m/%Y')"/>
                            </b>
                        </t>
                        <t t-else="">-</t>
                    </div>

                    <div style="font-size:7.5px;border:hidden">
                        <b>Use By:</b>
                        <t t-if="production and production.use_by_date">
                            <b>
                                <span t-esc="production.use_by_date.strftime('%d/%m/%Y')"/>
                            </b>
                        </t>

                        <t t-else="">-</t>
                    </div>

                    <div style="font-weight:bold; font-size:8.5px;border:hidden;border:hidden">
                        <t t-if="pricelist">
                            MRP: ₹
                            <span t-out="pricelist._get_product_price(product, 1, pricelist.currency_id or product.currency_id)"
                                  t-options="{'widget': 'monetary', 'display_currency': pricelist.currency_id or product.currency_id}"/>
                        </t>
                        <t t-else="">
                            MRP: ₹
                            <span t-esc="'{:.2f}'.format(product.lst_price)"/>
                        </t>
                    </div>

                    <div style="font-size:7.5px;">
                        <b>(Incl. Taxes)</b>
                    </div>
                </div>

                <div style="display:inline-block; vertical-align:middle; width:28%; text-align:right;border:hidden ">
                    <t t-set="qr_value" t-value="product.barcode"/>
                    <t t-if="qr_value">
                        <img t-att-src="'/report/barcode/QR/' + product.barcode + '?width=52&amp;height=52'"
                             alt="QR Code"
                             style="width:52px; height:52px; object-fit:contain; display:block; margin-left:auto;"/>
                    </t>
                    <t t-else="">
                        <span style="font-size:7px; color:gray;">No Barcode</span>
                    </t>
                </div>

            </div>
        </xpath>
    </template>


    <template id="report_productlabel_dymo_inherit" inherit_id="product.report_productlabel_dymo">
        <xpath expr="." position="replace">
            <t t-call="web.html_container">
                <!-- No table lines, gaps, or margins between labels -->
                <table style="width:100%; border-collapse:collapse; border-spacing:0; margin:0; padding:0; table-layout:fixed;">
                    <t t-foreach="quantity.items()" t-as="barcode_and_qty_by_product">
                        <t t-set="product" t-value="barcode_and_qty_by_product[0]"/>
                        <t t-foreach="barcode_and_qty_by_product[1]" t-as="barcode_and_qty">
                            <t t-set="qty_count" t-value="barcode_and_qty[1]"/>
                            <t t-foreach="range(0, qty_count, 2)" t-as="i">
                                <tr style="page-break-inside:avoid; height:32mm; vertical-align:top; border:hidden;">
                                    <td style="width:50%; border:none; margin:0; padding:0;border:hidden;">
                                        <div style="height:32mm; overflow:hidden; margin:0; padding:0;border:hidden;">
                                            <t t-call="product.report_simple_label_dymo"/>
                                        </div>
                                    </td>

                                    <t t-if="i + 1 &lt; qty_count">
                                        <td style="width:50%; border:none; margin:0; padding-left:20px;border:hidden;">
                                            <div style="height:32mm; overflow:hidden; margin:0; padding:0;">
                                                <t t-call="product.report_simple_label_dymo"/>
                                            </div>
                                        </td>
                                    </t>
                                    <t t-else="">
                                        <td style="width:50%; border:none; margin:0; padding:0;border:hidden;"/>
                                    </t>
                                </tr>
                            </t>
                        </t>
                    </t>
                </table>
            </t>
        </xpath>
    </template>
</odoo>
