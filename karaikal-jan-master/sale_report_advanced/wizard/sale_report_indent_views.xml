<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Views for sale report indent views -->
    <record id="indent_wizard" model="ir.ui.view">
        <field name="name">Product Sales Indent</field>
        <field name="model">sale.report.indent</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                    <field name="from_date" />
                        <field name="customer_id" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="to_date"/>
                        <field name="product_category_id" widget="many2many_tags"/>
                    </group>
                </group>
                <footer>
                    <button name="action_get_indent_report" string="PDF Report" type="object" class="btn-primary"/>
                    <button name="action_get_indent_xls_report" string="XLS Report" type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="sale_indent_report" model="ir.actions.act_window">
        <field name="name">Product Sales Indent Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.report.indent</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="indent_wizard"/>
        <field name="target">new</field>
    </record>

</odoo>
