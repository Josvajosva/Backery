<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="cc_pos.PartnerList" t-inherit="point_of_sale.PartnerList" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='header']/Input" position="before">
            <button t-if="!ui.isSmall" class="btn btn-success btn-lg lh-lg ms-2" role="img" aria-label="Quick create customer"
                    t-on-click="() => this.quickCreateCustomer()"
                    title="Quick create customer">
                Quick Create
            </button>
        </xpath>
    </t>

</templates>
