<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_helpdesk_ticket_type_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.search</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <search string="Helpdesk type Search">
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active','=',False)]"
                />
                <separator />
                <field name="name" filter_domain="[('name', 'ilike', self)]" />
                <field name="company_id" groups="base.group_multi_company" />
                <group>
                    <filter
                        string="Company"
                        name="company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"
                    />
                </group>
            </search>
        </field>
    </record>
    <record id="view_helpdesk_type_form" model="ir.ui.view">
        <field name="name">view.helpdesk_type.form</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Stages">
                <header />
                <sheet>
                    <widget
                        name="web_ribbon"
                        title="Archived"
                        bg_color="bg-danger"
                        invisible="active"
                    />

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" required="1" />
                        </h1>
                    </div>
                    <group name="main">
                        <field name="whatsapp_category"/>
                        <field name="whatsapp_option"/>
                        <field name="team_id" />
                        <field name="company_id" groups="base.group_multi_company" />
                        <field name="active" invisible="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_helpdesk_type_tree" model="ir.ui.view">
        <field name="name">view.helpdesk_type.list</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <list string="Types" multi_edit="1" sample="1">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="team_id"/>
                <field name="whatsapp_category"/>
                <field name="whatsapp_option"/>
                <field
                    name="company_id"
                    optional="hide"
                    groups="base.group_multi_company"
                />
            </list>
        </field>
    </record>

    <record id="helpdesk_ticket_type_action" model="ir.actions.act_window">
        <field name="name">Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">helpdesk.ticket.type</field>
        <field name="view_mode">list,form</field>
        <field name="path">helpdesk-types</field>
    </record>
    
    <menuitem
        id="helpdesk_ticket_type_menu"
        name="Types"
        parent="helpdesk.helpdesk_menu_config"
        action="helpdesk_ticket_type_action"
        sequence="1"
    />

</odoo>
