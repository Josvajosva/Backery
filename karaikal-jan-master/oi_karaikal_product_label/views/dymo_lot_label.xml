<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="lot_report_label_main_template">
        <t t-call="web.basic_layout">
            <t t-set="nRows" t-value="1"/>
            <t t-set="nCols" t-value="2"/>
            <t t-set="dymo_width" t-value="105"/>
            <t t-set="dymo_height" t-value="25"/>

            <div class="oe_structure"/>
            <div t-foreach="[docs[x:x + nRows * nCols] for x in range(0, len(docs), nRows * nCols)]" t-as="page_docs" class="o_label_sheet" t-att-style="'width: ' + str(dymo_width) + 'mm; height: ' + str(dymo_height) + 'mm;'">
                <t t-foreach="range(nRows)" t-as="row">
                    <div class="row" style="width: 100%;display: flex; justify-content: center; align-items: center;gap: 0px;">
                        <t t-foreach="range(nCols)" t-as="col">
                            <t t-set="o" t-value="page_docs[row * nCols + col]" t-if="row * nCols + col &lt; len(page_docs)"/>
                            <div class="col-3 mt-2" style="text-align: left; font-size: 8px; display: flex; flex-direction: column; gap: 0px;">
                                <div style="margin: 0; padding: 0; line-height: 1;">
                                    <strong>
                                        <span t-esc="o.product_id.name" style="font-size:10px"/>
                                    </strong>
                                </div>
                                <div style="margin: 0; padding: 0; line-height: 1;">
                                    <span style="font-size:8px" t-esc="o.name"/>
                                </div>
                                <div style="margin: 0; padding: 0; line-height: 1.3;">
                                    <strong>
                                        <span style="font-size:8px">MFG.Date : <span t-esc="o.create_date" t-options="{&quot;widget&quot;: &quot;date&quot;, &quot;format&quot;: &quot;dd/MM/yyyy&quot;}"/>
                                        </span>
                                    </strong>
                                </div>
                                <div style="margin: 0; padding: 0; line-height: 1.3;">
                                    <strong>
                                        <span style="font-size:8px">EXP.Date : <span t-esc="o.expiration_date" t-options="{&quot;widget&quot;: &quot;date&quot;, &quot;format&quot;: &quot;dd/MM/yyyy&quot;}"/>
                                        </span>
                                    </strong>
                                </div>
                                <div style="margin: 0; padding: 0; line-height: 1.3;">
                                    <strong>
                                        <span style="font-size:10px">MRP : ₹<span style="font-size:10px;" t-esc="'{:.2f}'.format(o.product_id.lst_price)"/>
                                        </span>
                                    </strong>
                                    <span style="font-size:8px"> (Incl.Taxes)</span>

                                </div>
                            </div>

                            <div class="col-3 mt-2" style="text-align: left; display: flex; justify-content: center;">
                                <t t-set="final_barcode" t-value="''"/>
                                <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1')">
                                    <t t-if="o.product_id.valid_ean" t-set="final_barcode" t-value="'01' + '0' * (14 - len(o.product_id.barcode)) + o.product_id.barcode"/>
                                    <t name="gs1_datamatrix_lot" t-if="o.product_id.tracking == 'lot'" t-set="final_barcode" t-value="(final_barcode or '') + '10' + o.name"/>
                                    <t t-elif="o.product_id.tracking == 'serial'" t-set="final_barcode" t-value="(final_barcode or '') + '21' + o.name"/>
                                </t>
                                <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1') and final_barcode">
                                    <span t-out="final_barcode" t-options="{'widget': 'barcode', 'symbology': 'ECC200DataMatrix', 'img_style': 'width:17mm; height:17mm'}"/>
                                </t>
                                <t t-else="">
                                    <span t-field="o.name" t-options="{'widget': 'barcode', 'img_style': 'width:17mm; height:17mm'}"/>
                                </t>
                            </div>

                        </t>
                    </div>
                </t>
                <div class="oe_structure"/>

            </div>
        </t>

    </template>
