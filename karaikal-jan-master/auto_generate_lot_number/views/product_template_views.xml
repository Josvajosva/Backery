<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    
    <record model="ir.ui.view" id="view_template_property_form_stock_account">
            <field name="name">view.template.property.form.stock.account</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="stock.view_template_property_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_tooltip']" position="after">
                <field name="digits"
                       invisible="is_auto_generate != True or tracking in ('none')"
                       required="is_auto_generate == True and tracking not in ('none')"/>
                <field name="prefix"
                       invisible="is_auto_generate != True or tracking in ('none')"
                       required="is_auto_generate == True and tracking not in ('none')"/>
                <field name="number_next" invisible="1"
                       groups="base.group_no_one"/>
                </xpath>
            </field>
</record>

</odoo>
