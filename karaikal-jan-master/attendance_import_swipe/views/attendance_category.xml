<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_hr_attendance_category_list" model="ir.ui.view">
        <field name="name">hr.attendance.category.list</field>
        <field name="model">hr.attendance.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="standard_hours"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_hr_attendance_category_form" model="ir.ui.view">
        <field name="name">hr.attendance.category.form</field>
        <field name="model">hr.attendance.category</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="standard_hours"/>
                    <field name="company_id"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_hr_attendance_category" model="ir.actions.act_window">
        <field name="name">Attendance Categories</field>
        <field name="res_model">hr.attendance.category</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="view_work_location_list" model="ir.ui.view">
        <field name="name">work.location.list</field>
        <field name="model">work.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_work_location_form" model="ir.ui.view">
        <field name="name">work.location.form</field>
        <field name="model">work.location</field>
        <field name="arch" type="xml">
            <form string="Work Location">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <record id="action_work_location" model="ir.actions.act_window">
        <field name="name">Work Locations</field>
        <field name="res_model">work.location</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create work locations for attendance and HR operations.
            </p>
        </field>
    </record>


    <record id="resource_calendar_form_inherit_work_location" model="ir.ui.view">
        <field name="name">resource.calendar.form.inherit.work.location</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='tz']" position="after">
                <field name="category"/>
            </xpath>

        </field>
    </record>


</odoo>