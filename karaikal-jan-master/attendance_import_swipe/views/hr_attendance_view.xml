<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_hr_attendance_tree_inherit_import" model="ir.ui.view">
        <field name="name">hr.attendance.tree.inherit.import</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='overtime_hours']" position="after">
                <field name="days" widget="float_time"/>
                <field name="category"/>
                <field name="location_id"/>
            </xpath>

        </field>
    </record>


    <record id="view_hr_attendance_form_inherit_import" model="ir.ui.view">
        <field name="name">hr.attendance.form.inherit.import</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='check_out']" position="after">
                <field name="category"/>
                <field name="location_id"/>
                <field name="days" />
            </xpath>

        </field>
    </record>


</odoo>
