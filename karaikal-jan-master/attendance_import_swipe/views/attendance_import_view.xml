<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_import_attendance_form" model="ir.ui.view">
        <field name="name">import.attendance.data.form</field>
        <field name="model">import.attendance.data</field>
        <field name="arch" type="xml">
            <form string="Import Card Swipe Attendance">
                <group>
                    <field name="import_option"/>
                    <field name="file_select" filename="attendance_file"/>
                </group>

                <footer>
                    <button name="import_file"
                            type="object"
                            string="Import"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_import" model="ir.actions.act_window">
        <field name="name">Import Card Swipe</field>
        <field name="res_model">import.attendance.data</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
