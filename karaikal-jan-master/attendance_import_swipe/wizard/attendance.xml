<odoo>
    <record id="view_attendance_location_wizard" model="ir.ui.view">
        <field name="name">attendance.location.wizard.form</field>
        <field name="model">attendance.location.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance Excel Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                    <field name="location_ids" widget="many2many_tags"/>
                    </group>
                </group>
                <footer>
                    <button
                        name="action_print_excel"
                        type="object"
                        string="Export Excel"
                        class="btn-primary"
                    />
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_location_wizard" model="ir.actions.act_window">
        <field name="name">Attendance Excel</field>
        <field name="res_model">attendance.location.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
