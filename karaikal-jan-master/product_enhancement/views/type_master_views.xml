<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_type_master_tree" model="ir.ui.view">
        <field name="name">type.master.tree</field>
        <field name="model">type.master</field>
        <field name="arch" type="xml">
            <list string="Type Master" editable="bottom">
                <field name="name" required="1"/>
                <field name="code" required="1"/>
            </list>
        </field>
    </record>

    <record id="view_type_master_form" model="ir.ui.view">
        <field name="name">type.master.form</field>
        <field name="model">type.master</field>
        <field name="arch" type="xml">
            <form string="Type Master">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g., Standard Type"/>
                            <field name="code" placeholder="e.g., STD"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_type_master_search" model="ir.ui.view">
        <field name="name">type.master.search</field>
        <field name="model">type.master</field>
        <field name="arch" type="xml">
            <search string="Type Master">
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <record id="action_type_master" model="ir.actions.act_window">
        <field name="name">Type Master</field>
        <field name="res_model">type.master</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_type_master_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new type master
            </p>
        </field>
    </record>

    <menuitem id="menu_type_master"
              name="Type Master"
              parent="sale.prod_config_main"
              action="action_type_master"
              sequence="35"/>
</odoo>
