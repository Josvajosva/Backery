<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_delivery_status_wizard_form" model="ir.ui.view">
            <field name="name">view.product.delivery.status.wizard.form</field>
            <field name="model">product.delivery.status</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="from_date"/>
                            <field name="product_category_ids" options="{'no_open': True, 'no_create': True}" widget="many2many_tags"/>
                            <field name="xls_file" readonly="1" filename="xls_filename" />
                        </group>
                        <group>
                            <field name="to_date"/>
                            <field name="xls_filename" readonly="1" />
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_xlsx" string="Print" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_product_delivery_status" model="ir.actions.act_window">
            <field name="name">Delivery Performance Report</field>
            <field name="res_model">product.delivery.status</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_product_sale_report" name="Reports" parent="sale.menu_sale_report" sequence="80"/>
        <menuitem id="menu_product_delivery_status" name="Delivery Performance Report" parent="menu_product_sale_report" action="action_product_delivery_status"/>

    </data>
</odoo>
