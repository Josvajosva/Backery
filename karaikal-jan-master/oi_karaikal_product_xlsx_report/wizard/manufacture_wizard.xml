<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_daily_product_production_report_wizard_form" model="ir.ui.view">
            <field name="name">daily.product.production.report.form</field>
            <field name="model">daily.product.production.report</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="xls_file" readonly="1" filename="xls_filename" />
                            <field name="xls_filename" readonly="1" />
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_xlsx" string="Print" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_daily_product_production_report" model="ir.actions.act_window">
            <field name="name">Daily Product Production Report</field>
            <field name="res_model">daily.product.production.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_daily_product_production_report" name="Daily Product Production Report" parent="mrp.menu_mrp_configuration" action="action_daily_product_production_report" sequence="150"/>

    </data>
</odoo>
