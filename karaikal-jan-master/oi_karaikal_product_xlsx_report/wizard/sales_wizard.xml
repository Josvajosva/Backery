<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sale_customer_category_wizard_form" model="ir.ui.view">
            <field name="name">view.sale.customer.category.wizard.form</field>
            <field name="model">sale.customer.category</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="from_date"/>
                            <field name="xls_file" readonly="1" filename="xls_filename" />
                            <field name="is_inter_company"/>
                        </group>
                        <group>
                            <field name="to_date"/>
                            <field name="xls_filename" readonly="1" />
                            <field name="is_tax_excluded"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_xlsx" string="Print" type="object" class="btn-primary" />
                        <button string="Cancel" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_sale_customer_category" model="ir.actions.act_window">
            <field name="name">Sales Report</field>
            <field name="res_model">sale.customer.category</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_sale_customer_category" name="Sales Report" parent="menu_product_sale_report" action="action_sale_customer_category" sequence="5"/>

    </data>
</odoo>
